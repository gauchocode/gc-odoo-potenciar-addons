<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gc_sale_invoice_import_wizard_form" model="ir.ui.view">
        <field name="name">gc.sale.invoice.import.wizard.form</field>
        <field name="model">gc.sale.invoice.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Importar facturas de venta desde Excel">
                <sheet>
                    <group invisible="context.get('show_log', False)">
                        <group>
                            <label for="file" string="Archivo Excel"/>
                            <div>
                                <field name="file" filename="filename" widget="binary" nolabel="1"/>
                                <field name="filename" invisible="1"/>
                            </div>
                        </group>
                        <group>
                            <field name="import_type"/>
                            <field name="option_token" invisible="1"/>
                            <field name="sheet_option_ids" invisible="1"/>
                            <field name="sheet_name" invisible="1"/>
                            <field name="sheet_option_id"
                                   domain="[('id', 'in', sheet_option_ids)]"
                                   options="{'no_create': True, 'no_open': True}"/>
                            <field name="create_partners"/>
                            <field name="fallback_product_id"/>
                        </group>
                    </group>

                    <group string="Preview de filas a importar" invisible="context.get('show_log', False)">
                        <group col="4">
                            <field name="preview_total_count" readonly="1"/>
                            <field name="preview_ready_count" readonly="1"/>
                            <field name="preview_duplicate_count" readonly="1"/>
                            <field name="preview_error_count" readonly="1"/>
                        </group>
                        <field name="preview_line_ids" nolabel="1" readonly="1">
                            <tree create="false" delete="false" edit="false">
                                <field name="row_number"/>
                                <field name="state"/>
                                <field name="invoice_date"/>
                                <field name="cuit"/>
                                <field name="partner_name"/>
                                <field name="comment"/>
                                <field name="journal_name"/>
                                <field name="line_amount_17"/>
                                <field name="line_amount_18"/>
                                <field name="vat_21"/>
                                <field name="total"/>
                                <field name="message"/>
                            </tree>
                        </field>
                    </group>

                    <div invisible="not context.get('show_log', False)">
                        <separator string="Resultado de la importación"/>
                        <field name="import_log" widget="text" nolabel="1" readonly="1"
                               style="width: 100%; min-height: 520px; font-family: monospace; white-space: pre-wrap; font-size: 12px;"/>
                    </div>
                </sheet>

                <footer>
                    <button string="Importar" name="action_import_invoices"
                            type="object" class="btn-primary"
                            invisible="context.get('show_log', False)"/>
                    <button string="Cerrar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_gc_sale_invoice_import_wizard" model="ir.actions.act_window">
        <field name="name">Importar facturas de venta</field>
        <field name="res_model">gc.sale.invoice.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">form,list</field>
    </record>
</odoo>
