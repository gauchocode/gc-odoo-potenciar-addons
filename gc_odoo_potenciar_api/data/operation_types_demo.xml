<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Tipo de Operación: Venta Simple -->
        <record id="operation_type_sale_simple" model="api.operation.type">
            <field name="name">Venta Simple</field>
            <field name="code">SALE_SIMPLE</field>
            <field name="description">Operación de venta simple con cuenta de ingresos y cuentas por cobrar</field>
            <field name="move_type">out_invoice</field>
            <field name="journal_id" ref="account.sales_journal"/>
        </record>

        <!-- Líneas para Venta Simple -->
        <record id="operation_line_sale_income" model="api.operation.line">
            <field name="operation_type_id" ref="operation_type_sale_simple"/>
            <field name="sequence">10</field>
            <field name="name">Ingresos por Ventas</field>
            <field name="account_id" ref="account.demo_sale_of_land_account"/>
            <field name="debit_credit">credit</field>
            <field name="amount_type">api_amount</field>
            <field name="partner_required">False</field>
        </record>

        <record id="operation_line_sale_receivable" model="api.operation.line">
            <field name="operation_type_id" ref="operation_type_sale_simple"/>
            <field name="sequence">20</field>
            <field name="name">Cuentas por Cobrar</field>
            <field name="account_id" ref="account.data_account_type_receivable"/>
            <field name="debit_credit">debit</field>
            <field name="amount_type">api_amount</field>
            <field name="partner_required">True</field>
        </record>

        <!-- Tipo de Operación: Pago Recibido -->
        <record id="operation_type_payment_received" model="api.operation.type">
            <field name="name">Pago Recibido</field>
            <field name="code">PAYMENT_IN</field>
            <field name="description">Registro de pago recibido de cliente</field>
            <field name="move_type">entry</field>
            <field name="journal_id" ref="account.bank_journal"/>
        </record>

        <!-- Líneas para Pago Recibido -->
        <record id="operation_line_payment_bank" model="api.operation.line">
            <field name="operation_type_id" ref="operation_type_payment_received"/>
            <field name="sequence">10</field>
            <field name="name">Banco</field>
            <field name="account_id" ref="account.cash"/>
            <field name="debit_credit">debit</field>
            <field name="amount_type">api_amount</field>
            <field name="partner_required">False</field>
        </record>

        <record id="operation_line_payment_receivable" model="api.operation.line">
            <field name="operation_type_id" ref="operation_type_payment_received"/>
            <field name="sequence">20</field>
            <field name="name">Cuentas por Cobrar</field>
            <field name="account_id" ref="account.data_account_type_receivable"/>
            <field name="debit_credit">credit</field>
            <field name="amount_type">api_amount</field>
            <field name="partner_required">True</field>
        </record>

        <!-- Tipo de Operación: Gasto -->
        <record id="operation_type_expense" model="api.operation.type">
            <field name="name">Gasto</field>
            <field name="code">EXPENSE</field>
            <field name="description">Registro de gasto simple</field>
            <field name="move_type">in_invoice</field>
            <field name="journal_id" ref="account.expenses_journal"/>
        </record>

        <!-- Líneas para Gasto -->
        <record id="operation_line_expense_cost" model="api.operation.line">
            <field name="operation_type_id" ref="operation_type_expense"/>
            <field name="sequence">10</field>
            <field name="name">Gasto</field>
            <field name="account_id" ref="account.demo_coffee_machine_account"/>
            <field name="debit_credit">debit</field>
            <field name="amount_type">api_amount</field>
            <field name="partner_required">False</field>
        </record>

        <record id="operation_line_expense_payable" model="api.operation.line">
            <field name="operation_type_id" ref="operation_type_expense"/>
            <field name="sequence">20</field>
            <field name="name">Cuentas por Pagar</field>
            <field name="account_id" ref="account.data_account_type_payable"/>
            <field name="debit_credit">credit</field>
            <field name="amount_type">api_amount</field>
            <field name="partner_required">True</field>
        </record>

    </data>
</odoo>