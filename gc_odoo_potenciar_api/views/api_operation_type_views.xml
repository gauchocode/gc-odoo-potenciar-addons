<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Vista de lista para Tipos de Operación -->
    <record id="view_api_operation_type_tree" model="ir.ui.view">
        <field name="name">api.operation.type.tree</field>
        <field name="model">api.operation.type</field>
        <field name="arch" type="xml">
            <tree string="Tipos de Operación">
                <field name="code"/>
                <field name="name"/>
                <field name="journal_id"/>
                <field name="move_type"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- Vista de formulario para Tipos de Operación -->
    <record id="view_api_operation_type_form" model="ir.ui.view">
        <field name="name">api.operation.type.form</field>
        <field name="model">api.operation.type</field>
        <field name="arch" type="xml">
            <form string="Tipo de Operación">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object"
                                class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button"
                                   options='{"terminology": "archive"}'/>
                        </button>
                    </div>
                    
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Nombre del tipo de operación"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="journal_id"/>
                            <field name="move_type"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    
                    <field name="description" placeholder="Descripción del tipo de operación..."/>
                    
                    <notebook>
                        <page string="Líneas de Operación" name="lines">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="account_id"/>
                                    <field name="debit_credit"/>
                                    <field name="amount_type"/>
                                    <field name="percentage" attrs="{'invisible': [('amount_type', '!=', 'percentage')], 'required': [('amount_type', '=', 'percentage')]}"/>
                                    <field name="partner_required"/>
                                    <field name="analytic_account_id" optional="hide"/>
                                    <field name="active"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista de búsqueda para Tipos de Operación -->
    <record id="view_api_operation_type_search" model="ir.ui.view">
        <field name="name">api.operation.type.search</field>
        <field name="model">api.operation.type</field>
        <field name="arch" type="xml">
            <search string="Buscar Tipos de Operación">
                <field name="name"/>
                <field name="code"/>
                <field name="journal_id"/>
                <separator/>
                <filter name="active" string="Activos" domain="[('active', '=', True)]"/>
                <filter name="inactive" string="Inactivos" domain="[('active', '=', False)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_journal" string="Diario" context="{'group_by': 'journal_id'}"/>
                    <filter name="group_move_type" string="Tipo de Movimiento" context="{'group_by': 'move_type'}"/>
                    <filter name="group_company" string="Compañía" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Acción para Tipos de Operación -->
    <record id="action_api_operation_type" model="ir.actions.act_window">
        <field name="name">Tipos de Operación</field>
        <field name="res_model">api.operation.type</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_api_operation_type_tree"/>
        <field name="search_view_id" ref="view_api_operation_type_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear un nuevo tipo de operación
            </p>
            <p>
                Los tipos de operación definen cómo se crearán los asientos contables
                cuando se reciban peticiones desde la API. Cada tipo de operación
                especifica el diario contable y las líneas con sus respectivas cuentas.
            </p>
        </field>
    </record>

    <!-- Vista de lista para Líneas de Operación -->
    <record id="view_api_operation_line_tree" model="ir.ui.view">
        <field name="name">api.operation.line.tree</field>
        <field name="model">api.operation.line</field>
        <field name="arch" type="xml">
            <tree string="Líneas de Operación">
                <field name="operation_type_id"/>
                <field name="sequence"/>
                <field name="name"/>
                <field name="account_id"/>
                <field name="debit_credit"/>
                <field name="amount_type"/>
                <field name="percentage"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- Vista de formulario para Líneas de Operación -->
    <record id="view_api_operation_line_form" model="ir.ui.view">
        <field name="name">api.operation.line.form</field>
        <field name="model">api.operation.line</field>
        <field name="arch" type="xml">
            <form string="Línea de Operación">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object"
                                class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button"
                                   options='{"terminology": "archive"}'/>
                        </button>
                    </div>
                    
                    <group>
                        <group>
                            <field name="operation_type_id"/>
                            <field name="sequence"/>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="account_id"/>
                            <field name="debit_credit"/>
                            <field name="amount_type"/>
                        </group>
                    </group>
                    
                    <group>
                        <group>
                            <field name="percentage" attrs="{'invisible': [('amount_type', '!=', 'percentage')], 'required': [('amount_type', '=', 'percentage')]}"/>
                        </group>
                        <group>
                            <field name="partner_required"/>
                            <field name="analytic_account_id"/>
                        </group>
                    </group>
                    
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción para Líneas de Operación -->
    <record id="action_api_operation_line" model="ir.actions.act_window">
        <field name="name">Líneas de Operación</field>
        <field name="res_model">api.operation.line</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_api_operation_line_tree"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear una nueva línea de operación
            </p>
            <p>
                Las líneas de operación definen las cuentas contables específicas
                y cómo se calcularán los importes para cada línea del asiento.
            </p>
        </field>
    </record>

</odoo>