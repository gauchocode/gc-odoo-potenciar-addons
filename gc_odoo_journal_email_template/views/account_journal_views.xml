<!-- views/account_journal_views.xml -->
<odoo>
  <record id="view_account_journal_form_inherit_mail_template" model="ir.ui.view">
    <field name="name">account.journal.form.inherit.mail.template</field>
    <field name="model">account.journal</field>
    <field name="type">form</field>
    <field name="inherit_id" ref="account.view_account_journal_form" />
    <field name="arch" type="xml">
      <xpath expr="//field[@name='mail_template_id']" position="after">
        <field name="invoice_mail_template_id"/>
      </xpath>
    </field>
  </record>
</odoo>
