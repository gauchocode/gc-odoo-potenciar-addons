<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data noupdate="1">

    <!-- PLANTILLA VENTAS #5 MAV -->
    <record id="email_template_factura_mav" model="mail.template">
      <field name="name">Factura - Ventas #5 MAV</field>
      <field name="email_from">{{ (user.email or 'administracion@potenciarsgr.com.ar') }}</field>
      <field name="subject">Factura {{object.name}} - POTENCIAR SGR</field>
      <field name="model_id" ref="account.model_account_move"/>
      <field name="auto_delete" eval="True"/>
      <field name="report_template" ref="account.account_invoices_without_payment"/>
      <field name="report_name">{{ (object.name or 'Factura') }}</field>
      <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
  <p style="box-sizing:border-box;margin: 0px; padding: 0px; font-size: 13px;">
    Estimado/a <t t-out="object.partner_id.name or ''"/>,<br/><br/>
    Aquí le adjuntamos su factura <span style="font-weight:bold;" t-out="object.name or ''"/> por un importe total de <span style="font-weight:bold;" t-out="format_amount(object.amount_total, object.currency_id) or ''"/> de parte de <t t-out="object.company_id.name or ''"/>.<br/>
    <br/>Estamos agradecidos de que opere con nosotros.<br/><br/>
    Ante cualquier duda o consulta no dude en comunicarse vía mail a <a href="mailto:administracion@potenciarsgr.com.ar">administracion@potenciarsgr.com.ar</a> o telefónicamente al <strong>0810-220-POTE (7683)</strong>.
  </p>
</div>
      </field>
    </record>

